// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}
datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  chats     Chat[]
  datasets   Dataset[]
  datasetColumns DatasetColumn[]
}

model Chat {
  id        Int      @id @default(autoincrement())
  name     String
  userId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  datasets   Dataset[]
  pipelineUrl String?
  trainingUrl String?
  modelMetrics String?
  chatsColumns DatasetColumn[]

}

model Dataset {
  id          Int      @id @default(autoincrement())
  userId      Int
  chatsId     Int
  datasetUrl String
  edaUrls    EdaUrls[]
  prediction Prediction?
  isTraining Boolean @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chats       Chat    @relation(fields: [chatsId], references: [id],onDelete: Cascade)

}
model EdaUrls {
  id        Int      @id @default(autoincrement())
  datasetId Int
  url       String
  dataset   Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
}
model DatasetColumn {
  id        Int      @id @default(autoincrement())
  chatsId   Int
  userId    Int
  columnName String
  columnType String
  targetColumn Boolean @default(false)
  chats    Chat  @relation(fields: [chatsId], references: [id], onDelete: Cascade)
  users    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Prediction {
  id        Int      @id @default(autoincrement())
  datasetId   Int  @unique
  predictionUrl String?
  dataset    Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
}